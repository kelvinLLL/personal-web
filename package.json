{
  "name": "personal-web",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "cd backend && .venv/bin/python -m pytest tests/ -v",
    "test:all": "npm test && npm run test:frontend && npm run test:backend",
    "dev": "node scripts/dev-all.mjs",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && .venv/bin/uvicorn main:app --reload --port 8000",
    "refresh:daily-nuance": "node scripts/refresh-daily-nuance.mjs",
    "build:portal": "node scripts/build-portal.mjs",
    "build:frontend": "npm --prefix frontend run build",
    "build:book-reader": "node scripts/build-book-reader.mjs",
    "build:daily-nuance": "node scripts/build-daily-nuance.mjs",
    "build": "node scripts/build-all.mjs",
    "dev:portal": "npm --prefix portal run dev"
  },
  "dependencies": {
    "http-proxy": "^1.18.1"
  }
}
